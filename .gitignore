__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
build_env_pyside/
build/
dist/
input/
output/
vgmstream-win64/
.vscode/
.DS_Store
usm_key_increment.json

# Keep tool docs, but do not version bundled binaries.
assets/tools/**
!assets/tools/**/
!assets/tools/**/*.md
!assets/tools/**/COPYING
!assets/tools/**/USAGE.md

# Allow ffmpeg shared-build runtime files to be versioned.
!assets/tools/ffmpeg/**/ffmpeg
!assets/tools/ffmpeg/**/ffmpeg.exe
!assets/tools/ffmpeg/**/*.dll
!assets/tools/ffmpeg/**/*.so
!assets/tools/ffmpeg/**/*.so.*
!assets/tools/ffmpeg/**/*.dylib

# Allow bundled vgmstream runtime files to be versioned.
!assets/tools/vgmstream/**/vgmstream-cli
!assets/tools/vgmstream/**/vgmstream-cli.exe
!assets/tools/vgmstream/**/vgmstream123
!assets/tools/vgmstream/**/*.dll
!assets/tools/vgmstream/**/*.so
!assets/tools/vgmstream/**/*.so.*
!assets/tools/vgmstream/**/*.dylib

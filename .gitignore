__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
build/
dist/
input/
output/
vgmstream-win64/
.DS_Store

# Keep tool docs, but do not version bundled binaries.
assets/tools/**
!assets/tools/**/
!assets/tools/**/*.md
!assets/tools/**/COPYING
!assets/tools/**/USAGE.md

# Allow ffmpeg shared-build runtime files to be versioned.
!assets/tools/ffmpeg/**/ffmpeg
!assets/tools/ffmpeg/**/ffmpeg.exe
!assets/tools/ffmpeg/**/*.dll
!assets/tools/ffmpeg/**/*.so
!assets/tools/ffmpeg/**/*.so.*
!assets/tools/ffmpeg/**/*.dylib
